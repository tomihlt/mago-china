{
  "expo": {
    "name": "El Mago China",
    "slug": "imm",
    "version": "2.0.0",
    "scheme": "imm",
    "orientation": "default",
    "icon": "./assets/mago-icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/mago-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3A8F"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos acceso a la cámara para fotografiar productos del inventario.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a la galería para seleccionar imágenes de productos.",
        "NSPhotoLibraryAddUsageDescription": "Necesitamos acceso para guardar imágenes del inventario."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/mago-icon.png",
        "backgroundColor": "#1A3A8F"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ],
      "package": "com.tomihlt.magochina"
    },
    "web": {
      "favicon": "./assets/mago-icon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font",
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para registrar productos.",
          "cameraPermission": "Necesitamos acceso a la cámara para fotografiar productos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para guardar imágenes del inventario.",
          "savePhotosPermission": "Necesitamos permiso para guardar fotos del inventario en tu galería.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "11138fb6-8bcc-4e11-b6cd-a33c00ee3291"
      }
    }
  }
}
